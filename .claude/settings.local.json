{
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(gh repo *)",
      "Bash(gh api *)",
      "Bash(node -e *)",
      "Bash(node --check *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "git push origin HEAD 2>&1 || true",
            "timeout": 60,
            "statusMessage": "Pushing to GitHub..."
          }
        ]
      }
    ]
  }
}
